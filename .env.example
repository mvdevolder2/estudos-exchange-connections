# ==============================================================================
# EXCHANGE CONNECTIONS - ENVIRONMENT VARIABLES EXAMPLE
# ==============================================================================
#
# Este arquivo contém TODAS as chaves API necessárias para testar
# e operar com as exchanges Binance, Bybit e OKX em:
#   - Modo Teste (Testnet) - Sem risco financeiro
#   - Modo Real (Mainnet) - Enolve dinheiro real
#
# ============ INSTRUÇÕES ============
#
# 1. Copie este arquivo para .env
# 2. Preencha apenas as chaves que você vai usar
# 3. Teste primeiro em modo Testnet
# 4. NUNCA use chaves com permissões de "withdraw" em produção
# 5. Revogue chaves de teste se suspeitar de vazamento
#
# ==============================================================================

# ============ BINAIRE ============

# --- Binance Spot Testnet (Sem risco) ---
# Acesso: https://testnet.binance.vision/
# Chaves necessárias: API Key + Secret Key
# Permissões necessárias: Reading + Spot & Margin Trading
BINANCE_SPOT_TEST_API_KEY=
BINANCE_SPOT_TEST_API_SECRET=

# --- Binance Futures Testnet (Sem risco) ---
# Acesso: https://testnet.binancefuture.com/
# Chaves necessárias: API Key + Secret Key
# Permissões necessárias: Reading + Futures Trading
BINANCE_FUTURES_TEST_API_KEY=
BINANCE_FUTURES_TEST_API_SECRET=

# --- Binance Spot Mainnet (Dinheiro real) ---
# Acesso: https://www.binance.com/
# Chaves necessárias: API Key + Secret Key
# Permissões necessárias: Reading + Spot & Margin Trading
# ⚠️ CUIDADO: Risco financeiro real
BINANCE_SPOT_MAIN_API_KEY=
BINANCE_SPOT_MAIN_API_SECRET=

# --- Binance Futures Mainnet (Dinheiro real) ---
# Acesso: https://www.binance.com/
# Chaves necessárias: API Key + Secret Key
# Permissões necessárias: Reading + Futures Trading
# ⚠️ CUIDADO: Risco financeiro real
BINANCE_FUTURES_MAIN_API_KEY=
BINANCE_FUTURES_MAIN_API_SECRET=

# ============ BYBIT ============

# --- Bybit Spot Testnet (Sem risco) ---
# Acesso: https://testnet.bybit.com/
# Chaves necessárias: API Key + Secret Key
# Permissões necessárias: Reading + Spot Trading
BYBIT_SPOT_TEST_API_KEY=
BYBIT_SPOT_TEST_API_SECRET=

# --- Bybit Linear Futures Testnet (Sem risco) ---
# Acesso: https://testnet.bybit.com/
# Chaves necessárias: API Key + Secret Key (Diferente do Spot)
# Permissões necessárias: Reading + Derivatives Trading
BYBIT_LINEAR_TEST_API_KEY=
BYBIT_LINEAR_TEST_API_SECRET=

# --- Bybit Spot Mainnet (Dinheiro real) ---
# Acesso: https://www.bybit.com/
# Chaves necessárias: API Key + Secret Key
# Permissões necessárias: Reading + Spot Trading
# ⚠️ CUIDADO: Risco financeiro real
BYBIT_SPOT_MAIN_API_KEY=
BYBIT_SPOT_MAIN_API_SECRET=

# --- Bybit Linear Futures Mainnet (Dinheiro real) ---
# Acesso: https://www.bybit.com/
# Chaves necessárias: API Key + Secret Key (Diferente do Spot)
# Permissões necessárias: Reading + Derivatives Trading
# ⚠️ CUIDADO: Risco financeiro real
BYBIT_LINEAR_MAIN_API_KEY=
BYBIT_LINEAR_MAIN_API_SECRET=

# ============ OKX ============

# --- OKX Demo Trading (Modo de simulação - sem risco) ---
# Acesso: https://www.okx.com/ (mude para "Demo Trading")
# Chaves necessárias: API Key + Secret Key + Passphrase
# Permissões necessárias: Reading + Trade
# ⚠️ IMPORTANTE: Header `x-simulated-trading: 1` será adicionado automaticamente
OKX_DEMO_API_KEY=
OKX_DEMO_API_SECRET=
OKX_DEMO_API_PASSPHRASE=

# --- OKX Mainnet (Dinheiro real) ---
# Acesso: https://www.okx.com/
# Chaves necessárias: API Key + Secret Key + Passphrase
# Permissões necessárias: Reading + Trade + Futures Trading
# ⚠️ CUIDADO: Risco financeiro real
OKX_MAIN_API_KEY=
OKX_MAIN_API_SECRET=
OKX_MAIN_API_PASSPHRASE=

# ==============================================================================
# CONFIGURAÇÕES GERAIS
# ==============================================================================

# Timeout para requisições REST (em segundos)
API_TIMEOUT=10

# Habilitar conexões WebSocket
ENABLE_WS=true

# Nível de logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ==============================================================================
# SEGURANÇA
# ==============================================================================
#
# NUNCA faça:
# ❌ Commitar este arquivo .env no GitHub
# ❌ Compartilhar chaves API em canais públicos
# ❌ Enviar chaves por e-mail, chat ou mensagem
# ❌ Usar chaves com permissões de "withdraw" em produção
#
# SEMPRE faça:
# ✅ Adicione .env ao .gitignore
# ✅ Use chaves com permissões mínimas necessárias (Read + Trade)
# ✅ Revoque chaves de teste periodicamente
# ✅ Use IPs whitelist nas exchanges quando possível
#
# ==============================================================================
